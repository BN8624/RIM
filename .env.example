# Repo Idea Miner 설정 예시. 이 파일을 .env로 복사하고 실제 값을 넣으세요.
# 실제 .env는 절대 커밋하지 마세요 (.gitignore가 막아줍니다).

# GitHub API token
GITHUB_TOKEN=

# Google AI Studio / Gemini Developer API keys (프로젝트당 1개, 최대 11개)
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=
GOOGLE_API_KEY_6=
GOOGLE_API_KEY_7=
GOOGLE_API_KEY_8=
GOOGLE_API_KEY_9=
GOOGLE_API_KEY_10=
GOOGLE_API_KEY_11=

# Gemma model
RIM_GEMMA_MODEL=gemma-4-31b-it

# LLM provider
RIM_LLM_PROVIDER=google_genai_gemma

# Key pool
RIM_KEY_POOL_STRATEGY=round_robin

# Retry policy
RIM_MAX_RETRIES_PER_CALL=3
RIM_RETRY_BACKOFF_STRATEGY=exponential_jitter
RIM_RETRY_INITIAL_DELAY_SECONDS=2
RIM_RETRY_MAX_DELAY_SECONDS=60
RIM_RESPECT_RETRY_AFTER=true
RIM_RETRY_AFTER_MAX_SECONDS=300

# Request timeout
RIM_REQUEST_TIMEOUT_SECONDS=180

# Generation behavior
RIM_TEMPERATURE=0.2
RIM_JSON_REPAIR_ATTEMPTS=1
