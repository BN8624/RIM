{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "properties": {
  "artifacts": {
   "items": {
    "properties": {
     "provenance": {
      "enum": [
       "AST_IMPORT",
       "AST_IO_CALL",
       "REGISTRY",
       "MANIFEST",
       "AST_STRING_LITERAL"
      ]
     },
     "role": {
      "enum": [
       "PRODUCES",
       "CONSUMES",
       "VALIDATES",
       "LITERAL_REFERENCE"
      ]
     }
    },
    "required": [
     "artifact_id",
     "path_pattern",
     "role",
     "symbol_id",
     "provenance",
     "source_path",
     "source_line"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "cli": {
   "items": {
    "required": [
     "command",
     "handler",
     "options"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "components": {
   "type": "object"
  },
  "contracts": {
   "items": {
    "required": [
     "contract_id",
     "owner_symbol",
     "consumer_symbols",
     "validator_symbols",
     "canon_ids",
     "compatibility",
     "risk"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "document_routes": {
   "items": {
    "required": [
     "route_id",
     "selectors",
     "canon_ids",
     "atlas_query"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "health": {
   "type": "object"
  },
  "invariants": {
   "items": {
    "required": [
     "invariant_id",
     "canon_id",
     "applies_to",
     "tests"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "modules": {
   "items": {
    "required": [
     "module",
     "path",
     "loc",
     "component",
     "public_symbols",
     "imports",
     "imported_by"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "repository": {
   "required": [
    "head",
    "structure_snapshot",
    "structural_fingerprint",
    "structural_diff"
   ],
   "type": "object"
  },
  "routes": {
   "items": {
    "required": [
     "route_id",
     "canon_ids",
     "cli",
     "steps"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "schema_version": {
   "const": 2
  },
  "symbols": {
   "items": {
    "required": [
     "symbol_id",
     "kind",
     "path",
     "start_line",
     "end_line",
     "signature",
     "component_id",
     "roles",
     "canon_ids",
     "related_tests"
    ],
    "type": "object"
   },
   "type": "array"
  },
  "test_paths": {
   "type": "object"
  },
  "tests": {
   "type": "object"
  },
  "validators": {
   "type": "object"
  }
 },
 "required": [
  "schema_version",
  "repository",
  "components",
  "modules",
  "symbols",
  "routes",
  "artifacts",
  "contracts",
  "invariants",
  "validators",
  "tests",
  "test_paths",
  "document_routes",
  "health"
 ],
 "title": "RIM Architecture Atlas",
 "type": "object"
}
